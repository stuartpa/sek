using PG; 

// Base configuration
config Base 
{
    action abstract static void SUT.AddJob(string name, int time, Frequency frequency); 	

    switch StepBound = 128;
    switch PathDepthBound = 128;
    switch TestClassBase = "vs";
    switch GeneratedTestPath = "..\\TestSuite";
    switch GeneratedTestNamespace = "SpecExplorerProject.TestSuite";
    switch TestEnabled = false;
	
	switch RecommendedViews = "CollapseLabelView";
}

// Product
config Product : Base
{
    action abstract static void SUT.AddJob(string name, int time, Frequency frequency)
      where {.
		Condition.In(name, "@$^", "t.cmd", "t.exe");
		Condition.In(time, -1, 60, 3600);
	  .};
}
machine Product() : Product
{
    AddJob || (construct model program from Product where scope="PG.ModelWithFrequency" ) 
}


// Interaction
config Interaction : Base
{
    action abstract static void SUT.AddJob(string name,int time, Frequency frequency)
      where {.
		Condition.In(name, "@$^", "t.cmd", "t.exe");
		Condition.In(time, -1, 60, 3600);
		Combination.Interaction(name);
		Combination.Interaction(time, frequency);
	  .};
}
machine Interaction() : Interaction
{
    AddJob || (construct model program from Interaction where scope="PG.ModelWithFrequency") 
}

// Pairwise
config Pairwise : Base
{
    action abstract static void SUT.AddJob(string name,int time, Frequency frequency)
      where {.
		Condition.In(name, "@$^", "t.cmd", "t.exe");
		Condition.In(time, -1, 60, 3600);
		Combination.Pairwise(name, time, frequency);
		Combination.Isolated(name == "@$^");
	    Combination.Isolated(time == -1);
	    Combination.Seeded(name == "t.exe", time == 3600); 
  .};
}
machine Pairwise() : Pairwise
{
    AddJob || (construct model program  from Pairwise where scope="PG.ModelWithFrequency") 
}

// Isolated
config Isolated : Base
{
    action abstract static void SUT.AddJob(string name,int time, Frequency frequency)
      where {.
		Condition.In(name, "@$^", "t.cmd", "t.exe");
		Condition.In(time, -1, 60, 3600);
		Combination.Interaction(name);
		Combination.Interaction(time, frequency);
		Combination.Isolated(name == "@$^");
	    Combination.Isolated(time == -1);
	  .};
}
machine Isolated() : Isolated
{
    AddJob || (construct model program  from Isolated where scope="PG.ModelWithFrequency") 
}

// Seeded
config Seeded : Base
{
    action abstract static void SUT.AddJob(string name,int time, Frequency frequency)
      where {.
		Condition.In(name, "@$^", "t.cmd", "t.exe");
		Condition.In(time, -1, 60, 3600);
		Combination.Interaction(name);
		Combination.Interaction(time, frequency);
		Combination.Isolated(name == "@$^");
	    Combination.Isolated(time == -1);
	    Combination.Seeded(name == "t.exe", time == 3600); 
	  .};
}
machine Seeded() : Seeded
{
    AddJob || (construct model program from Seeded where scope="PG.ModelWithFrequency") 
